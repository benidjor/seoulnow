# Seoul OpenAPI
SEOUL_OPENAPI_KEY=replace-me
SEOUL_SUBWAY_API_KEY=replace-me

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# HTTP receiver (Task 11.2) — Edge API → Kafka REST Proxy 의 Bearer 토큰.
# Cloudflare Pages Functions secret 과 동일 값을 공유한다. docker compose
# --profile receiver 기동 시 주입. 실제 값은 .env (gitignore) 에만 둔다.
RECEIVER_TOKEN=replace-with-random-secret

# Postgres (Day 6 CDC 에서 본격 사용, Day 1 부터 띄움)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=scp
POSTGRES_PASSWORD=scp_dev_password
POSTGRES_DB=scp

# MinIO (S3 호환)
# MINIO_ENDPOINT 는 호스트(macOS) 측 클라이언트 — Python producer / PyFlink / Spark — 가
# MinIO 에 접속할 때 쓰는 endpoint. **Day 6 진입 hotfix (PR α2)** 부터 docker hostname
# `minio` 로 통일 — Lakekeeper REST 가 `/v1/config` 의 `overrides.uri` 로 catalog uri 를
# vend 하면서 docker network 안 client (Airflow dbt subprocess) 까지 일관되게 작동하도록
# 하기 위함. host 측은 `/etc/hosts` 에 `127.0.0.1 minio` alias 를 추가해 동일 hostname 이
# host port mapping (9000:9000) 통과하도록 만든다 (README Quick Start 의 host setup 절).
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=http://minio:9000
MINIO_REGION=us-east-1
ICEBERG_WAREHOUSE_BUCKET=seoul-warehouse

# Lakekeeper REST Catalog
# host /etc/hosts 에 `127.0.0.1 lakekeeper` alias 가 있어야 host 측 client 가 8181:8181
# port mapping 으로 resolve. 자세한 사유는 위 MINIO_ENDPOINT 주석.
LAKEKEEPER_URL=http://lakekeeper:8181
ICEBERG_CATALOG_NAME=seoul

# Producer 폴링 주기 (초)
HOTSPOT_POLL_INTERVAL_SEC=300
SUBWAY_POLL_INTERVAL_SEC=60

# Airflow (Task 5.5+)
# - AIRFLOW_UID 는 host 사용자 UID 와 일치시켜 host bind mount (./airflow/logs)
#   의 ownership 충돌 회피. macOS 의 Docker Desktop 은 보통 50000 default 로 OK.
# - FERNET_KEY 는 Airflow connection password 암호화 — 1회 생성 후 .env 에 저장.
#   `python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"`
# - WEBSERVER__SECRET_KEY 는 webserver flash session 암호화 — 32 bytes random.
#   `python -c "import secrets; print(secrets.token_hex(32))"`
AIRFLOW_UID=50000
AIRFLOW_FERNET_KEY=replace-with-fernet-key
AIRFLOW__WEBSERVER__SECRET_KEY=replace-with-32-bytes-hex
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=admin

# Discord webhook (Task 5.6 dbt_full_run on_failure_callback)
# 빈 값이면 callback 이 stdout 로그만 출력 (placeholder behavior).
DISCORD_WEBHOOK_URL=
